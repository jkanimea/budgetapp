generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int           @id @default(autoincrement())
  name      String
  type      String        @default("EXPENSE")
  icon      String?
  color     String?
  budgets   Budget[]
  transactions Transaction[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([name, type])
}

model Transaction {
  id                   Int       @id @default(autoincrement())
  type                 String
  details              String?
  particulars          String?
  code                 String?
  reference            String?
  amount               Int
  date                 DateTime
  foreignCurrencyAmount Int?
  conversionCharge     Int?
  categoryId           Int?
  category             Category? @relation(fields: [categoryId], references: [id])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([date, amount])
  @@index([categoryId, date])
  @@index([type, reference])
}

model Budget {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @unique
  category    Category @relation(fields: [categoryId], references: [id])
  weeklyAmount Int
  startDate   DateTime

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
